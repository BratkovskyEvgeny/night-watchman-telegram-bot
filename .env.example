# Night Watchman — Переменные окружения
# Скопируйте этот файл в .env и заполните значения

# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен Telegram-бота (от @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ваш Telegram Chat ID (куда отправлять отчёты о спаме)
# Узнать свой ID можно у @userinfobot
ADMIN_CHAT_ID=your_chat_id_here

# ID администраторов через запятую (могут использовать /analytics в ЛС)
# Узнать свой ID можно у @userinfobot
ADMIN_USER_IDS=your_user_id_here

# Redis URL (для хранения состояния бота между перезапусками)
# Локально: redis://localhost:6379
# Railway: автоматически заполняется
REDIS_URL=redis://localhost:6379

# ==================== РЕКОМЕНДУЕМЫЕ ====================

# Mistral AI API ключ (для умного анализа спама)
# Получить бесплатно: https://console.mistral.ai/
# Бесплатный тариф: достаточно для большинства групп
MISTRAL_API_KEY=your_mistral_api_key_here

# ==================== ОПЦИОНАЛЬНЫЕ ====================

# Hugging Face API токен (для дополнительного ML-анализа)
# Получить бесплатно: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_token_here

# Директория для данных аналитики (по умолчанию: data/)
# ANALYTICS_DATA_DIR=data

# ID темы для PnL скриншотов (если используете темы в группе)
# PNL_TOPIC_ID=0
